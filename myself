    <title>Mora's STEM Project Website</title>
    <style>
        /* --- GREEN & BLUE MINIMALIST THEME (CSS) --- */
        :root {
            --primary-blue: #1e88e5;
            --accent-green: #2e7d32;
            --dark-navy: #0d47a1;
            --light-bg: #f4f9f4;
            --text-color: #333;
        }

        * {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
        }

        body {
            background-color: var(--light-bg);
            color: var(--text-color);
            line-height: 1.6;
            padding-bottom: 60px;
        }

        /* 4. NAVIGATION BAR */
        nav {
            background-color: var(--dark-navy);
            position: sticky;
            top: 0;
            z-index: 1000;
            display: flex;
            justify-content: center;
            padding: 15px;
        }

        nav a {
            color: white;
            text-decoration: none;
            margin: 0 15px;
            font-weight: bold;
            transition: color 0.3s;
        }

        nav a:hover {
            color: #a5d6a7;
        }

        /* 5. HEADER */
        header {
            background: linear-gradient(135deg, var(--primary-blue) 60%, var(--accent-green));
            color: white;
            text-align: center;
            padding: 60px 20px;
            box-shadow: 0 4px 6px rgba(0,0,0,0.1);
        }

        header h1 {
            font-size: 2.5rem;
            margin-bottom: 10px;
        }

        header p {
            font-style: italic;
            font-size: 1.1rem;
        }

        /* CONTAINER & SECTIONS */
        .container {
            max-width: 800px;
            margin: 30px auto;
            padding: 0 20px;
        }

        section {
            background: white;
            padding: 25px;
            margin-bottom: 30px;
            border-radius: 8px;
            border-left: 5px solid var(--accent-green);
            box-shadow: 0 2px 5px rgba(0,0,0,0.05);
        }

        h2 {
            color: var(--dark-navy);
            margin-bottom: 15px;
        }

        .champions-badge {
            background-color: var(--accent-green);
            color: white;
            display: inline-block;
            padding: 5px 10px;
            border-radius: 4px;
            font-weight: bold;
            margin-top: 10px;
        }

        /* 3. SLIDER GALLERY */
        .slider-container {
            position: relative;
            max-width: 100%;
            height: 250px;
            margin: 15px 0;
            overflow: hidden;
            border-radius: 6px;
            background-color: #eee;
        }

        .slide {
            display: none;
            width: 100%;
            height: 100%;
            justify-content: center;
            align-items: center;
            text-align: center;
            color: white;
            font-size: 1.5rem;
            font-weight: bold;
            padding: 20px;
        }

        /* Custom slide colors */
        .slide1 { background-color: var(--primary-blue); }
        .slide2 { background-color: var(--accent-green); }
        .slide3 { background-color: var(--dark-navy); }

        .slider-btn {
            position: absolute;
            top: 50%;
            transform: translateY(-50%);
            background: rgba(0,0,0,0.5);
            color: white;
            border: none;
            padding: 10px 15px;
            cursor: pointer;
            font-size: 18px;
        }

        .prev { left: 10px; }
        .next { right: 10px; }

        /* 1. GAME FUNCTIONALITY (Clicker Game) */
